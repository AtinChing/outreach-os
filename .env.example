# Master Ghost DB connection string — run `ghost create` then `ghost connect <id>`
MASTER_DATABASE_URL=
# When true, skip Ghost MCP and run research against MASTER_DATABASE_URL (same DB holds jobs + leads).
# docker-compose sets this for the backend service. Omit or false when using per-job Ghost databases.
# RESEARCH_USE_MASTER_DATABASE=1
# Backend calls Ghost via MCP (`ghost mcp start stdio`); the `ghost` binary must be on PATH and logged in.
# Optional overrides:
# GHOST_MCP_COMMAND=ghost
# GHOST_MCP_STDIO_ARGS=mcp,start,stdio
OPENAI_API_KEY=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AIRBYTE_API_KEY=
GOOGLE_MAPS_API_KEY=
HASDATA_API_KEY=
