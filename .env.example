# Master Ghost DB connection string — run `ghost create` then `ghost connect <id>`
MASTER_DATABASE_URL=
# Backend calls Ghost via MCP (`ghost mcp start stdio`); the `ghost` binary must be on PATH and logged in.
# Optional overrides:
# GHOST_MCP_COMMAND=ghost
# GHOST_MCP_STDIO_ARGS=mcp,start,stdio
OPENAI_API_KEY=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AIRBYTE_API_KEY=
GOOGLE_MAPS_API_KEY=
